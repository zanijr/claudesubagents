{
    "id": "code-analyzer",
    "name": "Code Analyzer Agent",
    "version": "1.0.0",
    "description": "Analyzes code for quality, patterns, complexity, and potential issues",
    "capabilities": [
        "code-review",
        "static-analysis",
        "complexity-analysis",
        "pattern-detection",
        "metrics"
    ],
    "triggers": [
        "analyze",
        "review",
        "quality",
        "complexity",
        "check code"
    ],
    "model": "sonnet",
    "input": {
        "required": ["code"],
        "optional": ["language", "context", "focusAreas"]
    },
    "output": {
        "successCriteria": ["issues array populated", "metrics provided", "recommendations given"]
    },
    "resources": {
        "maxConcurrentTasks": 3,
        "timeoutSeconds": 300
    }
}
